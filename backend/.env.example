# ──────────────────────────────────────────────────────────────────
# Kriya CRM — Backend env (Django)
# Copy to `.env` for local development. On Render, paste each value
# into the service's "Environment" tab instead of committing this.
# ──────────────────────────────────────────────────────────────────

# Set to "production" on Render; leave unset (or "development") locally.
DJANGO_ENV=development

# Generate a long random string for production.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me

# Only matters when DJANGO_ENV=production.
DJANGO_DEBUG=False

# Comma-separated. Render auto-adds its hostname, but list any custom
# domain you point at the service too.
ALLOWED_HOSTS=your-domain.com,crm-api.onrender.com

# The frontend URL(s). MUST include scheme. Comma-separated.
CORS_ALLOWED_ORIGINS=https://crm.your-domain.com,https://kriya-crm.onrender.com
CSRF_TRUSTED_ORIGINS=https://crm.your-domain.com,https://kriya-crm.onrender.com

# Database (Render PostgreSQL → set DATABASE_URL only, ignore the DB_* vars).
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Local fallback (used when DATABASE_URL is empty)
DB_NAME=kriya_crm_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis (Render Key-Value service). Optional — without it the cache
# falls back to LocMem and Celery workers won't run.
REDIS_URL=redis://red-xxx.onrender.com:6379
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Outgoing SMTP. Leave EMAIL_HOST unset to send mail to stdout instead.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# HTTPS redirect & HSTS — turn on once the deploy is confirmed healthy.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=0       # set to 31536000 (1 year) once stable

# AI / external service keys (only those you actually use).
GROQ_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

LOG_LEVEL=INFO
