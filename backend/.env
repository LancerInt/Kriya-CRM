DJANGO_ENV=development
DJANGO_SECRET_KEY=dev-secret-key-change-in-production-12345
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.development
DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_NAME=gtip_db
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1
ALLOWED_HOSTS=your-domain.com,crm-api.onrender.com
CORS_ALLOWED_ORIGINS=https://crm.your-domain.com,https://kriya-crm.onrender.com
CSRF_TRUSTED_ORIGINS=https://crm.your-domain.com,https://kriya-crm.onrender.com

# Outgoing SMTP. Leave EMAIL_HOST unset to send mail to stdout instead.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# HTTPS redirect & HSTS — turn on once the deploy is confirmed healthy.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=0       # set to 31536000 (1 year) once stable

# AI / external service keys (only those you actually use).
GROQ_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

LOG_LEVEL=INFO