# ──────────────────────────────────────────────────────────────────
# Kriya CRM — Frontend env (Next.js)
# Copy to `.env.local` for local development. On Render, set each
# variable in the service's "Environment" tab.
#
# NEXT_PUBLIC_* prefix is required — anything without it stays
# server-side and won't reach the browser bundle.
# ──────────────────────────────────────────────────────────────────

# Production: the Render URL of your backend web service, /api included.
# Local dev: http://localhost:8000/api
NEXT_PUBLIC_API_URL=https://kriya-crm-api.onrender.com/api
